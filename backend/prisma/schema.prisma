

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}
model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  nome     String

  /// eventos criados pelo usuário
  eventos   Evento[]
  participantes Participante[]
}

model Evento {
  id            String         @id @default(uuid())
  nome          String
  data          DateTime
  local         String
  status        String         // "Ativo" ou "Encerrado"
  
  // Quem criou o evento
  creatorId     String
  creator       User           @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  // Relações
  inscricoes    Inscricao[]    // Relação N:N com Participantes
  regras        RegraEvento[]  // Relação 1:N (Regra é exclusiva deste evento)
}

model Participante {
  id         String      @id @default(uuid())
  nome       String
  email      String      @unique
  creatorId     String
  creator       User           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  // Um participante pode estar em vários eventos
  inscricoes Inscricao[]
}

// Tabela de Junção (Pivot) entre Evento e Participante
model Inscricao {
  id             String       @id @default(uuid())
  checkIn        Boolean      @default(false)
  dataInscricao  DateTime     @default(now())
  
  eventoId       String
  evento         Evento       @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  
  participanteId String
  participante   Participante @relation(fields: [participanteId], references: [id], onDelete: Cascade)

  // Garante que o mesmo participante não se inscreva 2x no mesmo evento
  @@unique([eventoId, participanteId])
}

model RegraEvento {
  id            String   @id @default(uuid())
  nome          String   // ex: "QR Code", "Documento" (pode ser preenchido automaticamente pelo tipo)
  minutosAntes  Int
  minutosDepois Int
  obrigatorio   Boolean  @default(true)
  ativa         Boolean  @default(true)
  criadoEm      DateTime @default(now())
  
  eventoId      String
  evento        Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)

  // referência ao tipo de regra
  tipoRegraId   String
  tipoRegra     TipoRegra @relation(fields: [tipoRegraId], references: [id])
}

model TipoRegra {
  id    String  @id @default(uuid())
  nome  String  @unique

  regras RegraEvento[]
}